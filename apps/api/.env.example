# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_lab
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_SECRET=token-secret
JWT_EXPIRES_IN=24h

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080

# Logging
LOG_QUERIES=false
VERBOSE_ERRORS=false

# Support chat (Ollama). ShopLab is set up assuming llama3.2 (`ollama pull llama3.2`).
# Put the same tag here as `ollama list` shows — otherwise the API returns 502/503 for chat.
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_MS=120000
# OLLAMA_KEEP_ALIVE=45m
# OLLAMA_NUM_PREDICT=384
# OLLAMA_NUM_CTX=6144
# OLLAMA_TEMPERATURE=0.55
